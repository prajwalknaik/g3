pipeline{
agent any
tools{
gradle 'gradle'
jdk 'jdk'
}
stages{
    stage('checkout'){
        steps{
            git branch:'master',url:'https://github.com/prajwalknaik/g3.git'
  }
}
stage('build'){
    steps{
        sh 'gradle build'
  }
}
stage('test'){
    steps{
        sh 'gradle test'
  }
}
stage('run application'){
    steps{
        sh 'gradle run'
  }
}
}
post{
    success{
          echo 'build and deployment successfull'
}
    failure{
          echo 'build failed'
    }
}
}


